# OptDash Environment Configuration
# Copy to .env and adjust before running.
# All settings shown with their defaults. Uncomment and change as needed.

# ── Data Paths ──────────────────────────────────────────────────────
DUCKDB_PATH=data/optdash.duckdb
JOURNAL_DB_PATH=data/journal.db
DATA_ROOT=data

# ── API ─────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Underlyings ──────────────────────────────────────────────────────
# UNDERLYINGS must be a JSON list of strings.
# DEFAULT_UNDERLYING must be one of the values in UNDERLYINGS.
# SENSEX is not tracked — removed from defaults.
UNDERLYINGS=["NIFTY","BANKNIFTY","FINNIFTY","MIDCPNIFTY","NIFTYNXT50"]
# DEFAULT_UNDERLYING=NIFTY

# ── Scheduler ────────────────────────────────────────────────────────
# SCHEDULER_INTERVAL_SECONDS=300
# WS_INTERVAL_SECONDS=5

# ── Market Timing (HH:MM, 24-hour, zero-padded) ──────────────────────
# MARKET_OPEN=09:15
# MARKET_CLOSE=15:30
# EOD_FORCE_CLOSE_TIME=15:20
# EOD_SWEEP_TIME=15:25

# ── NSE Market Holidays 2026 ─────────────────────────────────────────
# Dates where NSE equity segment is fully closed (TRADING_HOLIDAY).
# Excludes settlement-only dates (Feb-19, Mar-19, Apr-01, Aug-26) and
# Diwali Muhurat session (Nov-08) where NSE trades with modified hours.
MARKET_HOLIDAYS=["2026-01-15","2026-01-26","2026-03-03","2026-03-26","2026-03-31","2026-04-03","2026-04-14","2026-05-01","2026-05-28","2026-06-26","2026-09-14","2026-10-02","2026-10-20","2026-11-10","2026-11-24","2026-12-25"]

# ── Session Boundaries ───────────────────────────────────────────────
# SESSION_OPENING_END=10:15
# SESSION_MIDDAY_START=11:30
# SESSION_MIDDAY_END=13:00
# SESSION_CLOSING_START=14:30
# DEALER_OCLOCK_START=14:00

# ── Data Retention ───────────────────────────────────────────────────
# RAW_PARQUET_RETENTION_DAYS=3
# DUCK_VIEW_LOOKBACK_DAYS=5

# ── Environment Gate ─────────────────────────────────────────────────
# GATE_GO_THRESHOLD=7
# GATE_WAIT_THRESHOLD=5
# GATE_MAX_SCORE=11

# ── AI Recommender ───────────────────────────────────────────────────
# PREFLIGHT_MIN_GATE_SCORE=5
# PREFLIGHT_MIN_CONFIDENCE=50
# PREFLIGHT_MAX_THETA_RATIO=0.03
# PREFLIGHT_MAX_PAIN_PROXIMITY=0.005
# PREFLIGHT_MIN_SSCORE=60.0
# PREFLIGHT_DTE1_MIN_GATE=7
# PREFLIGHT_DTE1_MIN_CONFIDENCE=65
# AI_SL_PCT=0.35          # FRACTIONAL (0.35 = 35%) — NOT a percentage integer
# AI_TARGET_MULT=1.50     # Must be > 1.0; target = entry * AI_TARGET_MULT
# AI_EXPIRY_MAX_SNAPS=3

# ── Position Management ──────────────────────────────────────────────
# TRAILING_STOP_ACTIVATION=0.20   # Activate trailing stop at +20% PnL
# GATE_SUSTAINED_NO_GO_SNAPS=2    # Exit after 2 consecutive NO_GO snaps

# ── Session Confidence ───────────────────────────────────────────────
# SESSION_MIDDAY_CONFIDENCE_PENALTY=10
# SESSION_CLOSING_CONFIDENCE_CAP=60  # CAP (upper bound), NOT a floor

# ── Strike Screener ──────────────────────────────────────────────────
# SCREENER_TOP_N=20
# SCREENER_MAX_MONEYNESS_PCT=5.0
# SCREENER_MIN_LIQUIDITY_CR=0.5
# SCREENER_MIN_DELTA=0.10
# SCREENER_MAX_DELTA=0.50
# SCREENER_MIN_EFF_RATIO=0.10

# ── IV ───────────────────────────────────────────────────────────────
# IV_LOOKBACK_DAYS=252

# ── GEX ──────────────────────────────────────────────────────────────
# GEX_NEAR_WEEKS=2
# GEX_DECLINE_THRESHOLD=0.70
# GEX_SCALING=1000000000.0

# ── CoC / V_CoC ──────────────────────────────────────────────────────
# VCOC_BULL_THRESHOLD=10.0
# VCOC_BEAR_THRESHOLD=-10.0
# VCOC_SPIKE_EXPIRY_SNAPS=3
# COC_DISCOUNT_THRESHOLD=-5.0

# ── OBI ──────────────────────────────────────────────────────────────
# OBI_THRESHOLD=0.10

# ── S_score Weights ──────────────────────────────────────────────────
# W_DELTA=4.0
# W_EFF_RATIO=4.0
# W_LIQUIDITY=3.0
# W_IV=2.0
# W_THETA=2.0
# W_GAMMA=1.0
# W_VEGA=1.0
# STAR_4_THRESHOLD=100.0
# STAR_3_THRESHOLD=80.0
# STAR_2_THRESHOLD=60.0
