# OptDash Environment Configuration
# Copy to .env and adjust paths before running.

# ── Data Paths ──────────────────────────────────────────────────────
DUCKDB_PATH=data/optdash.duckdb
JOURNAL_DB_PATH=data/journal.db
DATA_ROOT=data

# ── API ───────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Underlyings & Scheduler ──────────────────────────────────────────
UNDERLYINGS=["NIFTY","BANKNIFTY"]
SCHEDULER_INTERVAL_SECONDS=300
WS_INTERVAL_SECONDS=5

# ── AI Threshold Overrides (optional) ──────────────────────────────
# GATE_GO_THRESHOLD=7
# GATE_WAIT_THRESHOLD=5
# PREFLIGHT_MIN_CONFIDENCE=50
# AI_SL_PCT=0.35
# AI_TARGET_MULT=1.5
